{
  "functions": {
    "api/ai/*.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/ai/(.*)", "destination": "/api/ai/$1" }
  ],
  "headers": [
    {
      "source": "/api/ai/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
