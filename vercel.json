{
  "functions": {
    "api/ai/analyze.ts": { "maxDuration": 30 },
    "api/ai/stream.ts":  { "maxDuration": 30 },
    "api/ai/test.ts":    { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}
