{
  "buildCommand": "[ \"$VERCEL_PROJECT_ID\" = 'prj_mMQ2YkdMIlt6OZxAwDJF1jBtb8Uq' ] && vite build || echo 'Build skipped — not logisolve-sistema'",
  "outputDirectory": "dist",
  "functions": {
    "api/ai/analyze.ts": { "maxDuration": 30 },
    "api/ai/stream.ts":  { "maxDuration": 30 },
    "api/ai/test.ts":    { "maxDuration": 30 },
    "api/ai/debug.ts":    { "maxDuration": 30 },
    "api/ai/modules.ts":  { "maxDuration": 30 },
    "api/ai/sourcing.ts": { "maxDuration": 45 },
    "api/ai/chat.ts":    { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}
