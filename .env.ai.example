# ============================================================
# Logisolve AI Layer — Environment Variables
# Copy relevant vars to .env.local (never commit secrets)
# ============================================================

# ── Anthropic (SERVER-SIDE ONLY — never expose in frontend) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── AI Sandbox gate ───────────────────────────────────────────
# Set to "true" to enable the experimental AI panel
ENABLE_AI_EXPERIMENTAL=true
VITE_ENABLE_AI_EXPERIMENTAL=true   # also needed for frontend gate

# ── Sandbox auth (optional shared secret) ────────────────────
AI_SANDBOX_SECRET=your-sandbox-secret-here

# ── Cost controls ─────────────────────────────────────────────
AI_DAILY_TOKEN_LIMIT=200000         # soft cap per user per day

# ── Supabase (for logging) ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-side only — never in VITE_* vars

# ── Vercel (auto-set by Vercel, no action needed) ─────────────
# VERCEL_URL=logisolve.vercel.app
